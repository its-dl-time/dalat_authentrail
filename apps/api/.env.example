NODE_ENV=development
PORT=4000

# PostgreSQL — Railway tự cung cấp khi deploy
DATABASE_URL="postgresql://user:password@localhost:5432/dalat_authentrail"

# Redis — Railway tự cung cấp khi deploy
REDIS_URL="redis://localhost:6379"

# NextAuth secret — tạo bằng: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# CORS origin — địa chỉ frontend
CORS_ORIGIN="http://localhost:3000"
